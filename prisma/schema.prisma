datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum InvoiceStatus {
  DRAFT
  GENERATED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
}

enum MovementType {
  STOCK_ADD
  STOCK_REDUCE
  SALE
  ADJUSTMENT
  INVOICE_CANCELLED
}

model Client {
  id          String    @id @default(uuid())
  gstNumber   String?   @unique @map("gst_number") @db.VarChar(20)
  companyName String    @map("company_name") @db.VarChar(255)
  address     String?   @db.Text
  phone       String?   @db.VarChar(20)
  email       String?   @db.VarChar(255)
  invoices    Invoice[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("clients")
}

model Product {
  id           String              @id @default(uuid())
  productName  String              @map("product_name") @db.VarChar(255)
  hsnCode      String?             @map("hsn_code") @db.VarChar(50)
  unit         String              @db.VarChar(20)
  currentStock Decimal             @map("current_stock") @db.Decimal(12, 2)
  sellingPrice Decimal             @map("selling_price") @db.Decimal(12, 2)
  invoiceItems InvoiceItem[]
  movements    InventoryMovement[]
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  @@map("products")
}

model Invoice {
  id            String              @id @default(uuid())
  invoiceNumber String              @unique @map("invoice_number") @db.VarChar(50)
  clientId      String              @map("client_id")
  client        Client              @relation(fields: [clientId], references: [id])
  invoiceDate   DateTime            @map("invoice_date") @db.Date
  subtotal      Decimal             @db.Decimal(12, 2)
  cgstAmount    Decimal             @map("cgst_amount") @db.Decimal(12, 2)
  sgstAmount    Decimal             @map("sgst_amount") @db.Decimal(12, 2)
  igstAmount    Decimal             @map("igst_amount") @db.Decimal(12, 2)
  totalAmount   Decimal             @map("total_amount") @db.Decimal(12, 2)
  status        InvoiceStatus       @default(GENERATED)
  notes         String?             @db.Text
  items         InvoiceItem[]
  payment       Payment?
  movements     InventoryMovement[]
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  @@map("invoices")
}

model InvoiceItem {
  id            String   @id @default(uuid())
  invoiceId     String   @map("invoice_id")
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId     String?  @map("product_id")
  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName   String   @map("product_name") @db.VarChar(255)
  hsnCode       String?  @map("hsn_code") @db.VarChar(50)
  quantity      Decimal  @db.Decimal(12, 2)
  unit          String   @db.VarChar(20)
  rate          Decimal  @db.Decimal(12, 2)
  gstPercentage Decimal  @map("gst_percentage") @db.Decimal(5, 2)
  lineTotal     Decimal  @map("line_total") @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("invoice_items")
}

model Payment {
  id              String        @id @default(uuid())
  invoiceId       String        @unique @map("invoice_id")
  invoice         Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  totalAmount     Decimal       @map("total_amount") @db.Decimal(12, 2)
  paidAmount      Decimal       @map("paid_amount") @db.Decimal(12, 2)
  pendingAmount   Decimal       @map("pending_amount") @db.Decimal(12, 2)
  paymentStatus   PaymentStatus @default(PENDING) @map("payment_status")
  dueDate         DateTime?     @map("due_date") @db.Date
  lastPaymentDate DateTime?     @map("last_payment_date") @db.Date
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@map("payments")
}

model InventoryMovement {
  id             String       @id @default(uuid())
  productId      String       @map("product_id")
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  invoiceId      String?      @map("invoice_id")
  invoice        Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  movementType   MovementType @map("movement_type")
  quantityChange Decimal      @map("quantity_change") @db.Decimal(12, 2)
  stockBefore    Decimal      @map("stock_before") @db.Decimal(12, 2)
  stockAfter     Decimal      @map("stock_after") @db.Decimal(12, 2)
  remarks        String?      @db.Text
  createdAt      DateTime     @default(now()) @map("created_at")

  @@map("inventory_movements")
}
