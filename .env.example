# ============================================================
# Smart Billing System — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file.
# ============================================================

# ----------------------------------------------------------
# Database (Supabase PostgreSQL)
# ----------------------------------------------------------
# Connection pool URL — used at runtime (port 6543, PgBouncer)
DATABASE_URL="postgresql://postgres.[project-ref]:[your-password]@aws-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct URL — used for Prisma migrations only (port 5432)
DIRECT_URL="postgresql://postgres.[project-ref]:[your-password]@aws-[region].pooler.supabase.com:5432/postgres"

# ----------------------------------------------------------
# Invoice Defaults (NEXT_PUBLIC_ = accessible in browser)
# ----------------------------------------------------------
NEXT_PUBLIC_DEFAULT_INVOICE_PREFIX="INV-"
NEXT_PUBLIC_DEFAULT_DUE_DAYS="30"
NEXT_PUBLIC_SUPPLIER_STATE="Tamil Nadu"

# ----------------------------------------------------------
# Inventory threshold
# ----------------------------------------------------------
LOW_STOCK_THRESHOLD="50"

# ----------------------------------------------------------
# Company Information (used in PDF footer — server-side only)
# These are fallback values; the Settings screen in the app
# stores them in localStorage and passes them to the PDF API.
# ----------------------------------------------------------
COMPANY_NAME="Your Company Pvt Ltd"
COMPANY_ADDRESS="123 Industrial Area, City - 600001, State"
COMPANY_GST="22AAAAA0000A1Z5"
COMPANY_PHONE="+91 98765 43210"

# ----------------------------------------------------------
# Bank Details (PDF footer — server-side only)
# ----------------------------------------------------------
COMPANY_BANK_NAME="State Bank of India"
COMPANY_BANK_ACCOUNT="1234567890"
COMPANY_BANK_IFSC="SBIN0001234"
